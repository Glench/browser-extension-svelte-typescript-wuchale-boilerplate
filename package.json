{
    "name": "Browser extension Svelte Typescript Wuchale boilerplate",
    "description": "Boilerplate for Browser Extension Svelte Typescript Wuchale project",
    "version": "1.0.0",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/nekitcorp/chrome-extension-svelte-typescript-boilerplate.git"
    },
    "scripts": {
        "dev": "vite",
        "build": "npm run write_locales && vite build",
        "write_locales": "node write_extension_locales.ts",
        "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.7.1",
        "@sveltejs/vite-plugin-svelte": "7.2.0",
        "@tsconfig/svelte": "5.0.8",
        "@types/chrome": "0.2.2",
        "svelte": "^5.56.4",
        "svelte-check": "4.7.2",
        "tslib": "2.8.1",
        "typescript": "7.0.2",
        "vite": "^8.1.4"
    },
    "dependencies": {
        "@wuchale/svelte": "^0.20.5",
        "wuchale": "^0.25.6"
    }
}
